---
import { markdownToHtml } from "../utils/markdown.js";
import fs from "node:fs";
import {
    findReadme,
    getAllDirs,
    findCaseInsensitivePath,
} from "../utils/fs.js";
import ReadmeRenderer from "../components/ReadmeRenderer.astro";
import DirectoryList from "../components/DirectoryList.astro";
import path from "node:path";
import "../styles/global.css";

export function getStaticPaths() {
    const publicDir = path.join(process.cwd(), "public");
    const allDirs = getAllDirs(publicDir);
    const paths = [];

    for (const fullDirPath of allDirs) {
        const relativePath = path.relative(publicDir, fullDirPath);
        let readmeHtml = null;

        const readmePath = findReadme(fullDirPath);
        if (readmePath) {
            try {
                const mdContent = fs.readFileSync(readmePath, "utf-8");
                readmeHtml = markdownToHtml(mdContent);
            } catch (e) {
                console.error(`Failed to process README at ${readmePath}:`, e);
            }
        }

        paths.push({
            params: { path: relativePath },
            props: { readmeHtml },
        });
    }

    return paths;
}

import { getDirectoryItems, pathExists } from "../utils/fs.js";

let currentRelativePath = "";
let pathSegments = [];
let items = [];
let hasError = false;
let errorMessage = "";
const { readmeHtml } = Astro.props;

try {
    const rawPath = Astro.params.path;
    pathSegments =
        typeof rawPath === "string"
            ? rawPath.split("/")
            : Array.isArray(rawPath)
              ? rawPath
              : [];
    currentRelativePath = pathSegments.join("/");

    // Try to find the actual path in filesystem (case-insensitive)
    const publicDir = path.join(process.cwd(), "public");
    const requestedPath = path.join(publicDir, ...pathSegments);

    // First try direct path
    let currentFullPath = requestedPath;

    // If not found, try case-insensitive lookup
    if (!pathExists(currentFullPath)) {
        const foundPath = findCaseInsensitivePath(requestedPath);
        if (foundPath) {
            currentFullPath = foundPath;
            // Update relative path to match actual filesystem
            currentRelativePath = path.relative(publicDir, currentFullPath);
        }
    }

    if (pathExists(currentFullPath)) {
        const baseHref = currentRelativePath ? `/${currentRelativePath}` : "";
        items = getDirectoryItems(currentFullPath, baseHref);
    } else {
        hasError = true;
        errorMessage = "Directory does not exist.";
    }
} catch (err) {
    hasError = true;
    errorMessage = "Failed to read directory contents.";
    console.error(`FATAL ERROR /${currentRelativePath}`, err);
}
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Index /{currentRelativePath}</title>
        <meta
            name="description"
            content={`Browse files and subdirectories in /${currentRelativePath || ""}. Static Assets Index Generator, lightweight, blazingly fast`}
        />
    </head>
    <body>
        <main class="md-surface-container">
            {
                hasError ? (
                    <p class="md-error">{errorMessage}</p>
                ) : (
                    <>
                        <div class="md-headline">
                            <a href="/">
                                <svg class="md-icon" viewBox="0 0 24 24">
                                    <path d="M4 20q-.825 0-1.413-.588T2 18V6q0-.825.588-1.413T4 4h5l2 2h9q.825 0 1.413.588T22 8v10q0 .825-.588 1.413T20 20H4Z" />
                                </svg>
                                Root
                            </a>
                        </div>

                        <div class="md-breadcrumb">
                            <a href="/">Root</a>
                            {pathSegments.map((seg, i) => (
                                <>
                                    <span class="md-separator">/</span>
                                    <a
                                        href={
                                            "/" +
                                            pathSegments
                                                .slice(0, i + 1)
                                                .join("/")
                                        }
                                    >
                                        {seg}
                                    </a>
                                </>
                            ))}
                        </div>

                        <ReadmeRenderer readmeHtml={readmeHtml} />

                        <DirectoryList items={items} />
                    </>
                )
            }
        </main>
    </body>
</html>
