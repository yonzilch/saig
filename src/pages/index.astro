---
import { markdownToHtml } from "../utils/markdown.js";
import { findReadme, getDirectoryItems, readFile } from "../utils/fs.js";
import path from "node:path";
import ReadmeRenderer from "../components/ReadmeRenderer.astro";
import DirectoryList from "../components/DirectoryList.astro";
import "../styles/global.css";

const publicDir = path.join(process.cwd(), "public");

let readmeHtml: string | null = null;
const readmePath = findReadme(publicDir);
if (readmePath) {
    try {
        const mdContent = readFile(readmePath);
        readmeHtml = markdownToHtml(mdContent);
    } catch (e) {
        console.error(`Failed to process README at ${readmePath}:`, e);
    }
}

const items = getDirectoryItems(publicDir);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Static Assets</title>
        <meta
            name="description"
            content="Static Assets Index Generator, lightweight, blazingly fast"
        />
    </head>
    <body>
        <main class="md-surface-container">
            <div class="md-headline">
                <a href="/">
                    <svg class="md-icon" viewBox="0 0 24 24">
                        <path
                            d="M4 20q-.825 0-1.413-.588T2 18V6q0-.825.588-1.413T4 4h5l2 2h9q.825 0 1.413.588T22 8v10q0 .825-.588 1.413T20 20H4Z"
                        ></path>
                    </svg>
                    Root
                </a>
            </div>

            <ReadmeRenderer readmeHtml={readmeHtml} />

            <DirectoryList items={items} />
        </main>
    </body>
</html>
